<resources>
    <style name="AppTheme" parent="@style/AppTheme_Light" />

    <style name="AppTheme_Light" parent="@android:style/Theme.Material.Light.NoActionBar">
        <item name="android:fontFamily">sans</item>
        <item name="android:windowLightStatusBar">true</item>
        <item name="android:statusBarColor">@color/app_bg</item>
        <item name="android:navigationBarColor">@color/app_bg</item>
        <item name="android:windowBackground">@color/app_bg</item>
        <item name="android:colorAccent">@color/app_accent</item>
    </style>

    <style name="AppTheme_Dark" parent="@android:style/Theme.Material.NoActionBar">
        <item name="android:fontFamily">sans</item>
        <item name="android:windowLightStatusBar">false</item>
        <item name="android:statusBarColor">@color/app_bg</item>
        <item name="android:navigationBarColor">@color/app_bg</item>
        <item name="android:windowBackground">@color/app_bg</item>
        <item name="android:colorAccent">@color/app_accent</item>
    </style>
</resources>
